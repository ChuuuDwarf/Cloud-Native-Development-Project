# Multi-stage Python image for the FastAPI backend.
# Same image is used for the API server, Celery worker, and Celery beat
# (docker-compose overrides the command for worker / beat services).

FROM python:3.12-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# Install build deps for asyncpg / bcrypt (psycopg uses libpq).
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        libpq-dev \
        curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python deps in their own layer for caching.
COPY requirements.txt ./
RUN pip install -r requirements.txt

# Copy source.
COPY . .

# Drop perms — uvicorn / celery do not need root inside the container.
RUN useradd --create-home --shell /bin/bash app \
    && chown -R app:app /app
USER app

EXPOSE 8000

# Sensible default command; docker-compose overrides for celery worker / beat.
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]

HEALTHCHECK --interval=15s --timeout=5s --start-period=20s --retries=5 \
  CMD curl -fsS http://localhost:8000/health || exit 1
