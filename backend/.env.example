# Copy to .env for local dev (docker-compose reads these via the shell env, not this file)
ENV=development

# Database
DATABASE_URL=postgresql+asyncpg://lims:lims@localhost:5432/lims

# Redis (Celery broker + cache + SSE pub-sub)
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-in-prod-please
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:3000

# Email (use EMAIL_BACKEND=file for demo; smtp for real)
EMAIL_BACKEND=file
EMAIL_FROM=noreply@lims.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Uploads
UPLOADS_DIR=./uploads

# 中華電信 TAS phone callout (Sprint 3d)
# CHT_API_KEY 跟 CHT_SERVICE_NUMBER 由 SA 跟團隊拿。
# 沒設這兩個 -> backend 啟動 OK，撥電話的 task 會 log 後 skip，不影響其他通知。
# 詳細 setup 請看 docs/phone_api_demo.md。
CHT_API_KEY=
CHT_SERVICE_NUMBER=
CHT_BASE_URL=https://tasapi.cht.com.tw/apis/CHTIoT

# 所有 seed users 共用的 phone (demo 用，自己 demo 設成你自己手機)。
# 空字串 / 沒設 -> User.phone = NULL -> 通知時不撥電話 (只走站內 in-app 通道)。
DEMO_PHONE=
